{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -Command \"& { & (Join-Path $env:USERPROFILE '.codex\\hooks\\lightweight-codex-hook.ps1') }\"",
            "timeout": 10,
            "statusMessage": "Loading guardrails"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -Command \"& { & (Join-Path $env:USERPROFILE '.codex\\hooks\\lightweight-codex-hook.ps1') }\"",
            "timeout": 10,
            "statusMessage": "Applying guardrails"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|apply_patch|Edit|Write|functions\\..*|spawn_agent|send_input|wait_agent|close_agent|resume_agent|mcp__.*|multi_tool_use\\..*|tool_search\\..*|web\\..*|image_gen\\..*",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -Command \"& { & (Join-Path $env:USERPROFILE '.codex\\hooks\\lightweight-codex-hook.ps1') }\"",
            "timeout": 30,
            "statusMessage": "Checking immediate action safety"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "Bash|apply_patch|Edit|Write|functions\\..*|spawn_agent|send_input|wait_agent|close_agent|resume_agent|mcp__.*|multi_tool_use\\..*|tool_search\\..*|web\\..*|image_gen\\..*",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -Command \"& { & (Join-Path $env:USERPROFILE '.codex\\hooks\\lightweight-codex-hook.ps1') }\"",
            "timeout": 30,
            "statusMessage": "Checking approval request"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|apply_patch|Edit|Write|functions\\..*|spawn_agent|send_input|wait_agent|close_agent|resume_agent|mcp__.*|multi_tool_use\\..*|tool_search\\..*|web\\..*|image_gen\\..*",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -Command \"& { & (Join-Path $env:USERPROFILE '.codex\\hooks\\lightweight-codex-hook.ps1') }\"",
            "timeout": 30,
            "statusMessage": "Recording lightweight evidence"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -Command \"& { & (Join-Path $env:USERPROFILE '.codex\\hooks\\lightweight-codex-hook.ps1') }\"",
            "timeout": 30,
            "statusMessage": "Checking final evidence"
          }
        ]
      }
    ]
  }
}
