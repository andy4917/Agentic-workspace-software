{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -Command \"& { & (Join-Path $env:USERPROFILE '.codex\\hooks\\compact-codex-hook.ps1') }\"",
            "timeout": 10,
            "statusMessage": "Loading compact workspace rails"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -Command \"& { & (Join-Path $env:USERPROFILE '.codex\\hooks\\compact-codex-hook.ps1') }\"",
            "timeout": 10,
            "statusMessage": "Adding pending handoff and task frame"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|apply_patch|Edit|Write|functions\\..*|multi_tool_use\\..*|tool_search\\..*|web\\..*|image_gen\\..*|spawn_agent|send_input|wait_agent|close_agent|resume_agent|mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -Command \"& { & (Join-Path $env:USERPROFILE '.codex\\hooks\\compact-codex-hook.ps1') }\"",
            "timeout": 10,
            "statusMessage": "Checking compact safety gates"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|apply_patch|Edit|Write|functions\\..*|multi_tool_use\\..*|tool_search\\..*|web\\..*|image_gen\\..*|spawn_agent|send_input|wait_agent|close_agent|resume_agent|mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -Command \"& { & (Join-Path $env:USERPROFILE '.codex\\hooks\\compact-codex-hook.ps1') }\"",
            "timeout": 10,
            "statusMessage": "Recording compact turn state"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -Command \"& { & (Join-Path $env:USERPROFILE '.codex\\hooks\\compact-codex-hook.ps1') }\"",
            "timeout": 10,
            "statusMessage": "Recording next-turn handoff"
          }
        ]
      }
    ]
  }
}
