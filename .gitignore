# Audit-visible tool/package surfaces.
# Do not hide these: they are where stale bundled plugins, duplicate skills,
# abandoned bins, and unmanaged local environments have previously reappeared.
# plugins/
# bin/
# local-environments/
# profile.d/
# skills/
# agents/

# Managed external source checkouts used as local workstation runtimes.
# They are documented and verified by maintenance records, but should not be
# committed as embedded repositories or vendored package trees.
tools/memento-mcp/
tools/pgvector-v0.8.2/

# Local scratch and generated files
*.log
generated_images/
node_modules/
__pycache__/
*.pyc
maintenance/**/node_modules/
maintenance/**/.cache/
maintenance/**/coverage/
maintenance/patches/**/app.asar.*
maintenance/backups/
maintenance/diagnostics/

# Large local/reference material
maintenance/upstream/


# Quarantine/archive
_QUARANTINE/
maintenance/compressed/
archived_logs/
archived_worktrees/
archived_transient_roots/
archived_app_tool_caches/
archived_runtime_state/

# Generated maintenance reports stay local and audit-visible, but mutable run
# outputs are not tracked because each verification rewrites them.
reports/*.latest.json
reports/*.latest.md
maintenance/reports/*.latest.json
maintenance/reports/*.latest.md
reports/*results.jsonl
maintenance/reports/_tmp_*
trajectories/runs.jsonl
artifacts/compact-summaries/*.md
!artifacts/compact-summaries/README.md
artifacts/tool-results/*.txt

