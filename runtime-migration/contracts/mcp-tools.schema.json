{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MCP Tool Contract Inventory",
  "type": "object",
  "required": ["schema_version", "surfaces"],
  "properties": {
    "schema_version": { "const": 1 },
    "surfaces": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["surface_id", "transport", "tools"],
        "properties": {
          "surface_id": { "type": "string" },
          "transport": { "enum": ["stdio", "streamable_http", "sse"] },
          "initialize_contract": { "type": "object" },
          "tools": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "input_schema", "output_contract"],
              "properties": {
                "name": { "type": "string" },
                "input_schema": { "type": "object" },
                "output_contract": { "type": "string" },
                "error_contract": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
