{
  "profile": "codex_log_structured_sqlite_v1",
  "db": {
    "path": "%USERPROFILE%\\.codex\\state\\codex-log.sqlite",
    "separate_from_hooks_state": true,
    "hooks_state_path": "%USERPROFILE%\\.codex\\hooks\\state\\lightweight-status.json",
    "journal_mode": "WAL",
    "busy_timeout_ms": 10000
  },
  "record": {
    "hook_events": [
      "SessionStart",
      "UserPromptSubmit",
      "PreToolUse",
      "PermissionRequest",
      "PostToolUse",
      "Stop"
    ],
    "blocked_reasons": true,
    "not_ready_reasons": true,
    "changed_surfaces": true,
    "validation_results": true,
    "subagent_evidence": "accepted_or_rejected_only",
    "user_approvals": "approval_metadata_only"
  },
  "do_not_record": {
    "raw_secret_values": true,
    "raw_credential_file_contents": true,
    "full_prompt_text_by_default": true,
    "large_full_diffs_by_default": true,
    "authoritative_pass_or_complete_labels": true
  },
  "privacy": {
    "default_raw_content_storage": false,
    "payload_json_max_bytes": 4096,
    "text_value_max_chars": 240,
    "store_prompt_sha256_not_prompt": true,
    "store_diff_hash_not_diff": true,
    "redaction_failure_action": "drop_body_record_event_metadata"
  },
  "delete_policy": {
    "permanent_delete_default": false,
    "quarantine_folder_enabled": false,
    "move_to_recycle_bin_default": true,
    "dry_run_default": true,
    "archive_before_recycle_bin": true,
    "manifest_required": true,
    "sha256_required": true,
    "archive_verification_required": true,
    "fallback_to_permanent_delete": false,
    "user_empties_recycle_bin_manually": true
  },
  "limits": {
    "live_db_warn_mb": 250,
    "live_db_maintenance_mb": 500,
    "live_db_max_mb": 1024,
    "wal_warn_mb": 128,
    "single_raw_log_warn_mb": 50
  },
  "retention_days": {
    "raw_payload": 14,
    "event_summary": 180,
    "blocked_security_events": 365,
    "monthly_archives": 365
  },
  "sqlite_maintenance": {
    "never_delete_wal_or_shm_directly": true,
    "checkpoint_wal_if_large": true,
    "integrity_check_before_vacuum": true,
    "vacuum_into_before_rebuild": true
  }
}
