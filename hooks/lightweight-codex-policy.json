{
  "profile": "anti_reward_pm_workflow_v1",
  "autonomy": {
    "user_role": "reviewer_not_operator",
    "create_files_inside_scope": "allow",
    "edit_codex_workflow_files": "allow_when_requested_or_current_task_is_workflow_config",
    "use_new_tools_or_mcp": "allow_when_task_matches",
    "ask_before_destructive_action": true,
    "ask_before_secret_or_auth_content_access": true,
    "ask_before_legal_or_safety_decision": true,
    "ask_before_mutually_exclusive_goal_resolution": true,
    "ask_before_scope_expansion": true,
    "ask_before_external_side_effect": true
  },
  "subagents": {
    "max_parallel": 8,
    "max_depth": 1,
    "default_spawn_policy": "conditional_after_explicit_user_authorization",
    "explicit_user_authorization_required_by_runtime": true,
    "required_start_skill": "vowline",
    "required_start_skill_path": "%USERPROFILE%\\.agents\\skills\\vowline\\SKILL.md",
    "start_hook_behavior": "inject_vowline_context_for_subagent_session_start",
    "authorization_phrases": [
      "subagent",
      "sub-agent",
      "multi-agent",
      "parallel agent",
      "role separation",
      "delegate",
      "delegation",
      "PM-led"
    ],
    "spawn_threshold": "multi_surface_or_parallelizable_or_risk_or_repeated_failure",
    "must_not_delegate": "immediate_blocking_next_step_or_tightly_coupled_high_risk_work",
    "reuse_policy": "bounded_compatible_objective_surface_risk_repo_context",
    "stale_session_ttl_minutes": 60,
    "no_subagent_for": [
      "simple_conversation",
      "simple_explanation",
      "tiny_single_file_edit_without_risk",
      "image_generation_without_code_or_policy_work"
    ],
    "spawn_when": [
      "independent_exploration_needed",
      "review_dimensions_are_separable",
      "verification_can_run_in_parallel",
      "implementation_work_has_non_overlapping_file_ownership",
      "repeated_failure_or_unknown_root_cause",
      "security_or_auth_or_dependency_or_schema_or_hook_risk",
      "large_or_multi_surface_change"
    ]
  },
  "team_presets": {
    "enabled": [
      "review",
      "debug",
      "feature",
      "full_stack",
      "migration",
      "research",
      "security"
    ],
    "file_ownership_required": "true_for_parallel_implementation",
    "status_board_required": "true_for_team_preset_runs"
  },
  "goal_governance": {
    "goal_role": "long_running_tracking_marker_only",
    "pm_parent_goal_owner": "main_session",
    "subagent_goal_model": "contractual_subgoal_evidence_only",
    "subagent_completion_is_parent_completion": false,
    "final_audit_required_when_goal_or_surface_changed": true,
    "final_audit_required_fields": [
      "changed_surfaces",
      "acceptance_checks",
      "direct_checks_run",
      "direct_checks_not_run",
      "accepted_and_rejected_subagent_evidence",
      "pm_independent_verification",
      "residual_risks",
      "rollback_notes",
      "status_complete_blocked_or_continue"
    ],
    "resume_packet_required_fields": [
      "parent_goal",
      "acceptance_criteria",
      "accepted_evidence",
      "suspect_or_rejected_evidence",
      "open_risks",
      "changed_surfaces",
      "next_direct_verification_step"
    ]
  },
  "memory": {
    "provider": "memento",
    "authority": "support_only_never_completion_authority",
    "workspace": "global_pm",
    "session_start": [
      "context",
      "get_skill_guide_when_tool_behavior_is_unclear"
    ],
    "prompt_meta_frame": [
      "english_normalized_goal",
      "task_type",
      "authority_boundary",
      "toolchain_purpose",
      "evidence_target",
      "memory_action"
    ],
    "recall_before": [
      "hook_or_mcp_or_toolchain_change",
      "workflow_policy_change",
      "repeated_error_or_failed_verification",
      "prior_state_or_previous_decision_reference"
    ],
    "write_gate": [
      "durable_operational_value_only",
      "atomic_fragment",
      "verified_or_observed_assertion_status",
      "no_secrets_raw_logs_full_prompts_or_speculation"
    ],
    "feedback_after_recall": true,
    "legacy_memory_rag_policy": "contamination_not_active_fallback"
  },
  "work_size": {
    "tiny_files": 1,
    "tiny_changed_lines": 30,
    "normal_files_max": 3,
    "normal_changed_lines_max": 150,
    "large_files": 4,
    "large_changed_lines": 150,
    "multi_surface_threshold": 3,
    "threshold_behavior": "warn_plan_and_report_not_hard_block",
    "risky_change_always_high_ceremony": true
  },
  "work_classification": {
    "levels": {
      "L1": "tiny or simple answer/edit with minimal risk",
      "L2": "bounded ordinary engineering work",
      "L3": "multi-surface, delegated, workflow-sensitive, or long-running work",
      "L4": "P0/repeated-failure/root-cause workflow or harness incident, especially with explicit delegation"
    },
    "prompt_runtime_contract": [
      "emit task_class in UserPromptSubmit additionalContext",
      "store classification and English intent frame in hook state",
      "record delegation_authorized when the prompt authorizes subagents",
      "require goal action for L3/L4",
      "require watcher coverage or WATCHER_NOT_USED for L4 delegated incidents"
    ]
  },
  "size_limits": {
    "docs_file_lines": 800,
    "source_file_lines": 500,
    "function_lines": 80,
    "component_lines": 250,
    "generated_files_exempt": true,
    "behavior": "warn_with_split_or_justification",
    "finalization_blocking": "false_unless_size_growth_hides_behavior_or_breaks_validation"
  },
  "hooks": {
    "workflow_reminder": "inject",
    "safe_read_only_inspection": "observe",
    "ordinary_implementation": "observe",
    "large_or_risky_change_without_plan": "warn",
    "missing_final_evidence": "not_ready",
    "required_validation_missing": "not_ready",
    "dependency_schema_sync_missing": "not_ready",
    "prompt_secret_scan": "hard_block",
    "secret_content_access": "hard_block",
    "staged_diff_sensitive_scan": "allow_git_cached_diff_validation_without_direct_secret_file_read",
    "irreversible_destructive_action": "hard_block_unless_explicit",
    "hook_or_multi_agent_weakening": "hard_block_unless_explicit",
    "toolchain_mcp_cli_use_install": "observe_unless_secret_destructive_hook_weakening_without_explicit_scope_or_fake_success",
    "fake_success_insertion": "hard_block",
    "evaluator_or_exit_code_manipulation": "hard_block",
    "policy_fixture_risky_text": "observe",
    "safe_git_status_diff_add_commit": "allow"
  },
  "validation": {
    "docs": "readback",
    "config": "parser_check",
    "hooks": [
      "parser_check",
      "sample_allow_case",
      "sample_deny_or_not_ready_case"
    ],
    "dependencies": "lockfile_or_sync_validation_or_not_needed_reason",
    "schemas": "regeneration_or_static_consistency_check",
    "security": "explicit_risk_review",
    "git": [
      "git_status",
      "relevant_diff_or_log"
    ],
    "not_run_policy": "requires_reason"
  },
  "contamination": {
    "scan_product_code": true,
    "scan_control_scripts": true,
    "scan_tests": true,
    "scan_fixtures": true,
    "audit_policy_exempt": true,
    "negative_fixture_exempt": true,
    "exit_zero_policy": "product_or_control_script_unconditional_success_hard_block",
    "hidden_fallback_policy": "hard_block_unless_user_requested_or_explicitly_justified",
    "hardcoded_success_policy": "hard_block_for_product_and_control_code",
    "legacy_revival_policy": "warn_or_not_ready_if_unrequested",
    "broad_catch_all_success_policy": "hard_block",
    "warning_or_error_suppression_policy": "hard_block_unless_explicitly_justified"
  },
  "research": {
    "external_docs_required_for_version_sensitive_work": true,
    "checkout_required_for_repo_distillation": true,
    "representative_file_claims_full_tree": "prohibited",
    "citations_required_for_research_and_current_fact_claims": true,
    "source_recording_required": true
  },
  "git": {
    "status_before_git_action": true,
    "auto_commit_when_requested": true,
    "stage_scope": "current_requested_changes_only",
    "push_requires_explicit_request": true,
    "pr_default": "draft",
    "destructive_git_policy": "explicit_request_required",
    "protected_files_excluded": true
  },
  "reporting": {
    "status_board_trigger": [
      "multi_agent_run",
      "team_preset_run",
      "large_change",
      "multi_surface_change",
      "risky_change",
      "repeated_failure",
      "long_running_task"
    ],
    "changed_files_required": "true_for_modifications",
    "risks_required": "true_when_non_empty",
    "not_run_required": "true_when_any_check_not_run",
    "evidence_pack_policy": "separate_doc_for_long_evidence",
    "final_answer_style": "short_outcome_first"
  },
  "security": {
    "metadata_only_allowed": true,
    "copy_archive_sensitive_files": "blocked_by_default",
    "scope_expansion_policy": "explicit_user_instruction_required",
    "product_repo_boundary": "do_not_mutate_unless_current_task_targets_that_repo"
  },
  "toolchain_integrity": {
    "blocked_app_connector_tool_patterns": [
      "^mcp__codex_apps__supabase($|[._])",
      "^mcp__codex_apps__hugging_face($|[._])"
    ],
    "blocked_app_connector_reason": "Unintended Codex Apps connector tool is blocked. Remove or re-authorize the connector intentionally before use."
  }
}
